#!/bin/bash

RELATIVE_TO=$PWD
WITH_ICONS=false
BOLD_ROOT=false
TMUX_FMT=false

for arg in "$@"; do
    case $arg in
        --relative-to)
            shift
            RELATIVE_TO="$1"
            shift
            ;;
        --icons)
            WITH_ICONS=true
            shift
            ;;
        --bold)
            BOLD_ROOT=true
            shift
            ;;
        --tmux)
            TMUX_FMT=true
            shift
            ;;
        -*)
            echo "Unknown option: $arg"
            exit 1
            ;;
        *)
            # Ignore non-option arguments
            ;;
    esac
done

RAW_PATH=""
OUTPUT=""

BOLD_START=$(tput bold)
BOLD_END=$(tput sgr0)

if [[ "$TMUX_FMT" == true ]]; then
    BOLD_START="#[bold]"
    BOLD_END="#[nobold]"
fi

# In git repo
if git -C $RELATIVE_TO rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    # if [ "$WITH_ICONS" = true ]; then OUTPUT+=" "; fi
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󱌣 "; fi
    if [ "$BOLD_ROOT" = true ]; then OUTPUT+=$BOLD_START; fi
    OUTPUT+="$(basename "$(git -C $RELATIVE_TO rev-parse --show-toplevel 2>/dev/null)")"
    if [ "$BOLD_ROOT" = true ]; then OUTPUT+=$BOLD_END; fi

    RAW_PATH="$(git -C $RELATIVE_TO rev-parse --show-prefix 2>/dev/null)"
    if [ -n "$RAW_PATH" ]; then OUTPUT+="/"; fi
# In Google Drive
elif [[ "$RELATIVE_TO" == *"gdrive"* ]]; then
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󰉎 "; fi
    RAW_PATH=$RELATIVE_TO
# In home directory
elif [[ "$RELATIVE_TO" == "$HOME" ]]; then
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󱂵 "; fi
    RAW_PATH=$RELATIVE_TO
# Read-only directory
elif [ ! -w "$RELATIVE_TO" ]; then
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󰉐 "; fi
    RAW_PATH=$RELATIVE_TO
# Network path
elif [[ "$RELATIVE_TO" == *"//"* ]]; then
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󰡰 "; fi
    RAW_PATH=$RELATIVE_TO
else
    if [ "$WITH_ICONS" = true ]; then OUTPUT+="󰉋 "; fi
    RAW_PATH=$RELATIVE_TO
fi

# Substitute home directory with ~ (use sed for macOS compat)
RAW_PATH=$(sed "s|^$HOME|~|" <<< "$RAW_PATH")

IFS='/' read -ra FOLDERS <<< "$RAW_PATH"
if [ ${#FOLDERS[@]} -gt 5 ]; then
    if [[ "${FOLDERS[0]}" == .* ]]; then
        OUTPUT+="${FOLDERS[0]:0:2}/.../${FOLDERS[-1]}"
    else
        OUTPUT+="${FOLDERS[0]:0:1}/.../${FOLDERS[-1]}"
    fi
else
    for i in "${!FOLDERS[@]}"; do
        if [ $i -lt $((${#FOLDERS[@]} - 1)) ]; then
            if [[ "${FOLDERS[i]}" == .* ]]; then
                OUTPUT+="${FOLDERS[i]:0:2}/"
            else
                OUTPUT+="${FOLDERS[i]:0:1}/"
            fi
        else
            OUTPUT+="${FOLDERS[i]}"
        fi
    done
fi

echo "$OUTPUT"
