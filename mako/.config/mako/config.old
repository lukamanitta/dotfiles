sort=-time
layer=overlay
background-color=#0c0c0c
width=300
height=80
border-size=1
border-color=#303030
border-radius=12px
icons=0
max-icon-size=64
default-timeout=5000
ignore-timeout=1
max-visible=5
font=CaskaydiaMono Nerd Font Propo 11

[urgency=low]
border-color=#303030

[urgency=normal]
border-color=#303030

[urgency=high]
border-color=#cc5d4b
default-timeout=10000
